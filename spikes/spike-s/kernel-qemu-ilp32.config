# kernel-qemu-ilp32.config — QEMU virt optimisation fragment for Spike S.
#
# Applied on top of:
#   defconfig  (baseline; ensures systemd/SSH boot correctly)
#   64ilp32.config  (from K230 tree; enables ILP32 user-space compat ELF loader)
#
# What this fragment does:
#   1. Disables modules — largest single build speedup (~2× faster).
#   2. Disables K230-specific SoC drivers not present on QEMU virt machine.
#   3. Enables VirtIO MMIO (QEMU virt transport) + block + net + 9p.
#   4. Enables ext4 + vfat (Fedora rootfs + cloud-init FAT seed image).
#   5. Ensures seccomp filter support is enabled (the whole point of the spike).
#
# QEMU virt machine uses VirtIO MMIO — no PCI bus — so CONFIG_PCI can be off.
# Serial console is a 16550A UART at the standard QEMU virt address.
#
# After `make olddefconfig` the build system will resolve any dependencies
# that this fragment introduces or removes.

# ── No modules — biggest speedup ─────────────────────────────────────────────
# All needed drivers built-in.  Halves build time vs defconfig with modules.
# CONFIG_MODULES is not set

# ── Seccomp (mandatory for spike) ────────────────────────────────────────────
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ── VirtIO (QEMU virt machine) ────────────────────────────────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_RING=y

# ── 9p virtfs (spikes/ directory mount) ──────────────────────────────────────
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y
CONFIG_9P_FS_SECURITY=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# ── Console (16550A UART on QEMU virt) ───────────────────────────────────────
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_EARLY_PRINTK=y

# ── Network (virtio-net + SSH) ────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BLUETOOTH is not set

# ── Audit (needed for AUDIT_ARCH_RISCV32 in seccomp_data) ────────────────────
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# ── Namespaces + cgroups (systemd requires these) ─────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y

# ── Devtmpfs (udev) ───────────────────────────────────────────────────────────
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Disable K230 SoC platform drivers (not present on QEMU virt) ─────────────
# CONFIG_ARCH_CANAAN is not set
# CONFIG_CANAAN_K230 is not set

# ── Disable PCI (QEMU virt uses MMIO, not PCI) ───────────────────────────────
# CONFIG_PCI is not set

# ── Disable USB (not needed in QEMU virt for this spike) ─────────────────────
# CONFIG_USB is not set
# CONFIG_USB_SUPPORT is not set

# ── Disable sound ─────────────────────────────────────────────────────────────
# CONFIG_SOUND is not set

# ── Disable netfilter (not needed; IPVS/xt_mark errors in c-sky tree) ─────────
# CONFIG_NETFILTER is not set
# CONFIG_NF_CONNTRACK is not set
# CONFIG_IP_VS is not set

# ── Disable IOMMU / IOMMU drivers ────────────────────────────────────────────
# CONFIG_IOMMU_SUPPORT is not set

# ── Disable FPGA / remoteproc / RPMsg (K230-specific) ────────────────────────
# CONFIG_FPGA is not set
# CONFIG_REMOTEPROC is not set
# CONFIG_RPMSG is not set

# ── Crypto minimum (ext4 + virtio use this) ───────────────────────────────────
CONFIG_CRYPTO=y
CONFIG_CRYPTO_CRC32C=y

# ── DMA ───────────────────────────────────────────────────────────────────────
CONFIG_DMA_ENGINE=y

# ── Clock events ─────────────────────────────────────────────────────────────
CONFIG_RISCV_TIMER=y
CONFIG_CLINT_TIMER=y

# ── SMP (QEMU -smp 4) ─────────────────────────────────────────────────────────
CONFIG_SMP=y
CONFIG_NR_CPUS=8
