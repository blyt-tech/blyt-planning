# rv32emu config for Spike A
# RV32IMFC interpreter, no SDL, no JIT — matches the fc32 minimum emulation target

# RISC-V ISA: I + M + F + C (no A — not needed for CoreMark/Embench)
CONFIG_RV32I=y
# CONFIG_RV32E is not set
CONFIG_EXT_M=y
# CONFIG_EXT_A is not set
CONFIG_EXT_F=y
CONFIG_EXT_C=y
CONFIG_Zicsr=y
CONFIG_Zifencei=y
# CONFIG_Zba is not set
# CONFIG_Zbb is not set
# CONFIG_Zbc is not set
# CONFIG_Zbs is not set

# Execution mode: interpreter only
CONFIG_INTERPRETER_ONLY=y
# CONFIG_JIT is not set
# CONFIG_T2C is not set
# CONFIG_SYSTEM is not set
CONFIG_ELF_LOADER=y

# Performance
CONFIG_MOP_FUSION=y
CONFIG_BLOCK_CHAINING=y
CONFIG_LTO=y
CONFIG_OPTIMIZE_LEVEL=2
# CONFIG_OPTIMIZE_SIZE is not set
# CONFIG_DEBUG_SYMBOLS is not set

# No graphics or audio (headless benchmark host)
# CONFIG_SDL is not set
# CONFIG_SDL_MIXER is not set

# Misc
CONFIG_LOG_COLOR=y
# CONFIG_GDBSTUB is not set
# CONFIG_UBSAN is not set
# CONFIG_ARCH_TEST is not set

CONFIG_CONFIGURED=y
