# Host-side WASM build staging directory (generated by make stage-3-wasm-build)
# Contains staged Lua sources, patched rv32emu sources, compiled .o files,
# and the final consolelua-hybrid.js/.wasm output.
wasm-build/

# Built ELF files and object archives (generated by docker-build targets)
# (individual digests are committed; the ELF binaries are not)
elfs/*.elf
elfs/*.ld
elfs/*.a
elfs/test_call_on_demand
