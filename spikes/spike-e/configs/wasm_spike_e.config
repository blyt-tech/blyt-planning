# rv32emu config for Spike E
# RV32IMFC interpreter, no SDL, no JIT, ELF loader on, WASM target.
# Matches spikes/spike-a/configs/rv32emu.config but adds CONFIG_BUILD_WASM=y.

CONFIG_RV32I=y
# CONFIG_RV32E is not set
CONFIG_EXT_M=y
# CONFIG_EXT_A is not set
CONFIG_EXT_F=y
CONFIG_EXT_C=y
CONFIG_Zicsr=y
CONFIG_Zifencei=y
# CONFIG_Zba is not set
# CONFIG_Zbb is not set
# CONFIG_Zbc is not set
# CONFIG_Zbs is not set

CONFIG_INTERPRETER_ONLY=y
# CONFIG_JIT is not set
# CONFIG_T2C is not set
# CONFIG_SYSTEM is not set
CONFIG_ELF_LOADER=y

CONFIG_MOP_FUSION=y
CONFIG_BLOCK_CHAINING=y
# LTO with emcc + Mac CCACHE / mimalloc combo has been a recurring source of
# upstream warnings; the wasm_defconfig disables it explicitly, so we do too.
# CONFIG_LTO is not set
CONFIG_OPTIMIZE_LEVEL=3
# CONFIG_OPTIMIZE_SIZE is not set
# CONFIG_DEBUG_SYMBOLS is not set

# CONFIG_SDL is not set
# CONFIG_SDL_MIXER is not set

CONFIG_LOG_COLOR=y
# CONFIG_GDBSTUB is not set
# CONFIG_UBSAN is not set
# CONFIG_ARCH_TEST is not set

# WebAssembly target
CONFIG_BUILD_WASM=y

CONFIG_CONFIGURED=y
